# ── ProjectHub Backend Environment Variables ──────────────────────────────────
# Copy this to .env and fill in values

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projecthub
# Production (use RDS Proxy endpoint for Lambda):
# DATABASE_URL=postgresql://projecthub_app:PASSWORD@projecthub-proxy.proxy-xxx.region.rds.amazonaws.com:5432/projecthub

DB_POOL_MIN=1
DB_POOL_MAX=10

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_256BIT_RANDOM_SECRET
JWT_ACCESS_EXPIRE_MINUTES=480

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=http://localhost:3000

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET=projecthub-assets
